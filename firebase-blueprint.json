{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information and their saved temporary email accounts.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique ID of the user from Firebase Auth."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's primary email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "savedAccounts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "address": { "type": "string" },
              "password": { "type": "string" },
              "token": { "type": "string" }
            }
          },
          "description": "List of temporary email accounts saved by the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the profile was created."
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles stored by their unique UID."
    }
  }
}
